# ========================================
# Clinicboard — Environment Variables
# ========================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# Required for Supabase CLI migrations (supabase db push)
SUPABASE_DB_PASSWORD=your-db-password-here

# PHI Encryption (AES-256)
# Generate a secure key: openssl rand -base64 32
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# Rate Limiting & Security (Upstash Redis)
# Create a free Redis database at https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token-here

# Session Management
# Timeout in minutes for user inactivity
SESSION_TIMEOUT_MINUTES=10

# Application
# In production, set this to your Vercel deployment URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
